<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.music.mapper.SystemNoticeMapper">

    <resultMap id="BaseResultMap" type="com.example.music.entity.SystemNotice">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="type" property="type"/>
        <result column="is_active" property="isActive"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_time" property="updatedTime"/>
    </resultMap>

    <sql id="BaseColumns">
        id, title, content, type, is_active, created_time, updated_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM system_notice WHERE id = #{id}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM system_notice
        <where>
            <if test="type != null and type != ''">
                AND type = #{type}
            </if>
        </where>
        ORDER BY created_time DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countList" resultType="long">
        SELECT COUNT(*) FROM system_notice
        <where>
            <if test="type != null and type != ''">
                AND type = #{type}
            </if>
        </where>
    </select>

    <select id="selectActive" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM system_notice
        WHERE is_active = TRUE ORDER BY created_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO system_notice (title, content, type, is_active)
        VALUES (#{title}, #{content}, #{type}, #{isActive})
    </insert>

    <update id="update">
        UPDATE system_notice
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="type != null">type = #{type},</if>
            <if test="isActive != null">is_active = #{isActive},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM system_notice WHERE id = #{id}
    </delete>

</mapper>
