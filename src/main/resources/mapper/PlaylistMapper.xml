<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.music.mapper.PlaylistMapper">

    <resultMap id="BaseResultMap" type="com.example.music.entity.Playlist">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="cover_url" property="coverUrl"/>
        <result column="is_public" property="isPublic"/>
        <result column="song_count" property="songCount"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_time" property="updatedTime"/>
    </resultMap>

    <sql id="BaseColumns">
        id, user_id, title, description, cover_url, is_public, song_count, created_time, updated_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM playlist WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM playlist
        WHERE user_id = #{userId}
        ORDER BY created_time DESC
    </select>

    <select id="selectPublicByUserId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM playlist
        WHERE user_id = #{userId} AND is_public = 1
        ORDER BY created_time DESC
    </select>

    <select id="selectPublic" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM playlist
        WHERE is_public = 1
        ORDER BY created_time DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countPublic" resultType="long">
        SELECT COUNT(*) FROM playlist WHERE is_public = 1
    </select>

    <select id="countTotal" resultType="long">
        SELECT COUNT(*) FROM playlist
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO playlist (user_id, title, description, cover_url, is_public, song_count)
        VALUES (#{userId}, #{title}, #{description}, #{coverUrl},
                COALESCE(#{isPublic}, 1), 0)
    </insert>

    <update id="update">
        UPDATE playlist
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="description != null">description = #{description},</if>
            <if test="coverUrl != null">cover_url = #{coverUrl},</if>
            <if test="isPublic != null">is_public = #{isPublic},</if>
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateSongCount">
        UPDATE playlist SET song_count = #{count} WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM playlist WHERE id = #{id}
    </delete>

</mapper>
