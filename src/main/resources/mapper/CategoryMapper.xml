<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.music.mapper.CategoryMapper">

    <resultMap id="BaseResultMap" type="com.example.music.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="type" property="type"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_time" property="updatedTime"/>
    </resultMap>

    <sql id="BaseColumns">
        id, name, type, sort_order, created_time, updated_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM category WHERE id = #{id}
    </select>

    <select id="selectByType" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM category
        WHERE type = #{type}
        ORDER BY sort_order ASC
    </select>

    <select id="selectByNameAndType" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM category
        WHERE name = #{name} AND type = #{type}
        LIMIT 1
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM category
        ORDER BY type, sort_order ASC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, type, sort_order)
        VALUES (#{name}, #{type}, #{sortOrder})
    </insert>

    <update id="update">
        UPDATE category
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM category WHERE id = #{id}
    </delete>

</mapper>