<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.music.mapper.RoomMessageMapper">

    <resultMap id="BaseResultMap" type="com.example.music.entity.RoomMessage">
        <id column="id" property="id"/>
        <result column="room_id" property="roomId"/>
        <result column="user_id" property="userId"/>
        <result column="type" property="type"/>
        <result column="content" property="content"/>
        <result column="created_time" property="createdTime"/>
    </resultMap>

    <sql id="BaseColumns">
        id, room_id, user_id, type, content, created_time
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO room_message (room_id, user_id, type, content, created_time)
        VALUES (#{roomId}, #{userId}, #{type}, #{content}, NOW())
    </insert>

    <select id="selectRecent" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM room_message
        WHERE room_id = #{roomId}
        ORDER BY created_time DESC
        LIMIT #{limit}
    </select>

</mapper>
