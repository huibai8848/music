<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.music.mapper.OperationLogMapper">

    <resultMap id="BaseResultMap" type="com.example.music.entity.OperationLog">
        <id column="id" property="id"/>
        <result column="operator_id" property="operatorId"/>
        <result column="action" property="action"/>
        <result column="target_type" property="targetType"/>
        <result column="target_id" property="targetId"/>
        <result column="detail" property="detail"/>
        <result column="ip" property="ip"/>
        <result column="created_time" property="createdTime"/>
    </resultMap>

    <sql id="BaseColumns">
        id, operator_id, action, target_type, target_id, detail, ip, created_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM operation_log WHERE id = #{id}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM operation_log
        <where>
            <if test="action != null and action != ''">
                AND action = #{action}
            </if>
            <if test="operatorId != null">
                AND operator_id = #{operatorId}
            </if>
        </where>
        ORDER BY created_time DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countList" resultType="long">
        SELECT COUNT(*) FROM operation_log
        <where>
            <if test="action != null and action != ''">
                AND action = #{action}
            </if>
            <if test="operatorId != null">
                AND operator_id = #{operatorId}
            </if>
        </where>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO operation_log (operator_id, action, target_type, target_id, detail, ip)
        VALUES (#{operatorId}, #{action}, #{targetType}, #{targetId}, #{detail}, #{ip})
    </insert>

</mapper>
