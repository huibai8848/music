{
	"mcpServers": {
        "mysql-mcp": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "@pickstar-2002/mysql-mcp@latest"
          ],
          "env": {
            "MYSQL_HOST": "localhost",
            "MYSQL_PORT": "3306",
            "MYSQL_USER": "root",
            "MYSQL_PASSWORD": "123456",
            "MYSQL_DATABASE": "test"
          }
        },
        "drawio-mcp": {
          "command": "npx",
          "args": [
            "-y",
            "@drawio/mcp"
          ]
        }
      }
}